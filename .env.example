# Stripe credentials for e2e payment tests.
# Get these from your connected Stripe account in the dev environment:
#   npx wp-env run cli -- wp option pluck mission_settings stripe_site_token
#   npx wp-env run cli -- wp option pluck mission_settings stripe_account_id
#
# MISSION_STRIPE_TEST_TOKEN=your_token_here
# MISSION_STRIPE_ACCOUNT_ID=acct_xxx
