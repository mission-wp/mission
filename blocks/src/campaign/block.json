{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mission/campaign",
	"version": "0.1.0",
	"title": "Campaign Card",
	"category": "mission",
	"icon": "megaphone",
	"description": "Display a campaign as a card with image, progress, and a link to its page.",
	"supports": {
		"html": false,
		"interactivity": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"campaignId": {
			"type": "number",
			"default": 0
		},
		"showImage": {
			"type": "boolean",
			"default": true
		},
		"showTag": {
			"type": "boolean",
			"default": true
		},
		"showDescription": {
			"type": "boolean",
			"default": true
		},
		"showProgressBar": {
			"type": "boolean",
			"default": true
		},
		"showDonorCount": {
			"type": "boolean",
			"default": true
		},
		"buttonText": {
			"type": "string",
			"default": "View Campaign"
		}
	},
	"example": {},
	"textdomain": "missionwp-donation-platform",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScriptModule": "file:./view.js",
	"render": "file:./index.php"
}
